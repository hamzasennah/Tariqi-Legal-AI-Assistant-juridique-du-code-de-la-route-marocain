OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# hashing = demo locale sans API ; openai = embeddings OpenAI.
TARIQI_EMBEDDING_BACKEND=hashing

# Chemins par défaut.
TARIQI_CORPUS_PATH=data/seed/legal_corpus.jsonl
TARIQI_INFRACTIONS_CSV=data/structured/infractions_maroc.csv
TARIQI_PROCEDURES_PATH=data/structured/procedures.json
TARIQI_INDEX_PATH=vectorstore/tariqi_index.json

# auto = utilise le LLM seulement si OPENAI_API_KEY existe.
TARIQI_USE_OPENAI_ANSWER=auto
